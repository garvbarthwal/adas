# ---- Backend REST API base URL ----
# e.g. http://localhost:8000  (dev)  |  https://api.example.com  (prod)
VITE_API_BASE_URL=http://localhost:8000

# ---- Backend WebSocket base URL ----
# ws:// in dev, wss:// in prod. Channels /ws/detections and /ws/metrics are
# appended automatically.
VITE_WS_BASE_URL=ws://localhost:8000

# ---- MediaMTX WebRTC (WHEP) endpoint for the video stream ----
# MediaMTX serves WHEP at http(s)://<host>:8889/<path>/whep
# e.g. http://localhost:8889/carcam/whep  |  https://media.example.com/carcam/whep
VITE_WEBRTC_URL=http://localhost:8889/carcam/whep

# ---- Default camera id (matches backend CAMERA_ID) ----
VITE_CAMERA_ID=carcam
