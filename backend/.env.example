# ---- Service ----
APP_NAME="ADAS Detection Backend"
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS / WebSocket origins.
# Use the exact Vercel URL(s) in production, e.g. https://your-app.vercel.app
CORS_ORIGINS=*

# ---- Ingest mode ----
# rtsp   = production: pull RTSP from MediaMTX (Raspberry Pi → FFmpeg → MediaMTX)
# webrtc = development "Browser Camera Mode": the browser publishes its webcam
#          directly to the backend (no FFmpeg, no MediaMTX). Requires
#          requirements-dev.txt (aiortc). STREAM_URL is ignored in this mode.
INGEST_MODE=rtsp

# ---- Stream (single camera default) ----
STREAM_URL=rtsp://localhost:8554/carcam
CAMERA_ID=carcam
STREAM_RECONNECT_DELAY=2.0
STREAM_STALE_AFTER=5.0

# ---- Multiple cameras (optional) ----
# When set, this JSON array OVERRIDES STREAM_URL/CAMERA_ID above. Example:
# CAMERAS=[{"camera_id":"carcam1","stream_url":"rtsp://localhost:8554/carcam1","name":"Front"},{"camera_id":"carcam2","stream_url":"rtsp://localhost:8554/carcam2","name":"Rear"}]
CAMERAS=

# ---- Detection engine ----
MODEL=yolov8n.pt
DETECTION_FPS=10                 # detection cadence; camera may run at 30 FPS
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
TRACKER=bytetrack.yaml
DEVICE=cpu                       # cpu | cuda | 0
